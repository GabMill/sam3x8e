# sam3x8e/.clangd — clangd per-project configuration
#
# WHY THIS FILE EXISTS
# ─────────────────────
# clangd needs to know the compiler flags for each source file so it can
# parse includes, resolve types, and provide correct diagnostics.  The
# authoritative source of flags is compile_commands.json, generated by
# running "make compile_commands" inside the build container.
#
# This file provides a fallback that works BEFORE compile_commands.json
# has been generated, and also sets the cross-compilation target so
# clangd (which is a native x86-64 binary) correctly models the ARM ABI.
#
# HOW clangd FINDS THIS FILE
# ───────────────────────────
# clangd walks up from the file being edited until it finds a .clangd
# config file.  Placing this file at sam3x8e/ means every file under
# sam3x8e/src/ (and the vendor headers) picks up these flags.
#
# CROSS-COMPILATION TARGET
# ─────────────────────────
# --target=arm-none-eabi tells clangd to model the ARM Cortex-M ABI:
#   - sizeof(int)   = 4 (same as x86-64, so less critical here)
#   - sizeof(void*) = 4 (32-bit pointers; clangd will not warn about
#                        size mismatches between pointer and uint32_t)
#   - Calling convention, struct alignment, etc. match the target.
#
# Without the target triple, clangd defaults to x86-64 and will report
# false positives like "comparison between pointer and integer" for
# CMSIS register access macros that use uint32_t pointer casts.

CompileFlags:
  Add:
    # Cross-compilation target: ARM bare metal, 32-bit, Thumb-2 only
    - --target=arm-none-eabi
    - -mcpu=cortex-m3
    - -mthumb

    # Freestanding build: no hosted C library assumptions
    - -ffreestanding

    # Suppress unaligned access (see Makefile comment for why)
    - -mno-unaligned-access

    # Select the SAM3X8E device variant in the vendor headers
    - -D__SAM3X8E__

    # Include paths (relative to sam3x8e/ project root)
    - -Isrc
    - -Ivendor/sam/include
    - -Ivendor/cmsis/include

  # When compile_commands.json is present, its per-file flags take
  # precedence over the Add list above.  The Add entries act as a
  # baseline that fills gaps (e.g. files not in compile_commands.json).
  CompilationDatabase: .
