{
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [80, 100],
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,

    "files.associations": {
        "*.ld": "linkerscript",
        "Makefile": "makefile",
        "Dockerfile": "dockerfile",
        "compose.yml": "dockercompose"
    },

    "clangd.arguments": [
        "--background-index",
        "--clang-tidy"
    ],
    "C_Cpp.intelliSenseEngine": "disabled",

    "makefile.makefilePath": "${workspaceFolder}/make/Makefile",
    "makefile.configureOnOpen": false,

    "github.copilot.editor.enableAutoCompletions": false,
    "editor.inlineSuggest.enabled": false,

    "search.exclude": { "**/obj/**": true, "**/out/**": true, "**/vendor/**": true },
    "files.exclude": { "**/.DS_Store": true },

    "filewatcher.commands": [
        {
            "match": "src/.*\\.c$",
            "isAsync": true,
            "event": "onFileCreate",
            "cmd": "cd ${workspaceFolder} && docker compose -f docker/compose.yml run --rm build make -f make/Makefile compile_commands"
        },
        {
            "match": "src/.*\\.c$",
            "isAsync": true,
            "event": "onFileDelete",
            "cmd": "cd ${workspaceFolder} && docker compose -f docker/compose.yml run --rm build make -f make/Makefile compile_commands"
        },
        {
            "match": "make/Makefile",
            "isAsync": true,
            "event": "onFileChange",
            "cmd": "cd ${workspaceFolder} && docker compose -f docker/compose.yml run --rm build make -f make/Makefile compile_commands"
        }
    ]
}
